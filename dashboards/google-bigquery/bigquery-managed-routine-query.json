{
    "displayName": "BigQuery Managed Routine Query Monitoring",
    "dashboardFilters": [
        {
            "filterType": "RESOURCE_LABEL",
            "labelKey": "query_job_id",
            "templateVariable": "",
            "valueType": "STRING_ARRAY"
        }
